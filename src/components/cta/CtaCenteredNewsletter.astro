---
---

<section id="newsletter" class="overflow-hidden py-24">
  <div class="site-container">
    <div
      class="relative overflow-hidden rounded-2xl border px-6 py-14 md:px-12"
      style="background: var(--color-bid-surface); border-color: var(--color-bid-border);"
      data-mos="fade-up"
      data-mos-delay="0.3"
    >
      <!-- Subtle background accent -->
      <div
        class="pointer-events-none absolute -top-32 -right-32 h-72 w-72 rounded-full opacity-[0.06]"
        style="background: radial-gradient(circle, #8365EE 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-xl text-center">
        <!-- Badge -->
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.1em]"
          style="color: var(--color-bid-coral); background: rgba(107,79,207,0.06); border-color: rgba(107,79,207,0.18);"
        >
          ◦ Monthly newsletter
        </div>

        <!-- Heading -->
        <h2
          class="mb-4 font-heading text-[clamp(1.6rem,4vw,2.25rem)] font-extrabold leading-[1.1] tracking-tight"
          style="color: var(--color-bid-text);"
        >
          Once a month.<br />Worth reading.
        </h2>

        <!-- Body -->
        <p
          class="mx-auto mb-10 max-w-md"
          style="font-family: var(--font-serif); font-size: 15px; line-height: 1.75; color: var(--color-bid-text-secondary);"
        >
          Each issue takes one complex system — technology, AI, organizations, strategy —
          and breaks it down. What the research actually finds. What the conventional wisdom
          misses. What it means for the decisions you make.
        </p>

        <!-- Form -->
        <form class="flex flex-col gap-3 sm:flex-row" onsubmit="return false;">
          <input
            type="email"
            placeholder="your@email.com"
            required
            class="h-11 flex-1 rounded-[10px] border px-4 text-sm outline-none transition-all focus:ring-2"
            style="background: var(--color-bid-bg); border-color: var(--color-bid-border); color: var(--color-bid-text); --tw-ring-color: rgba(131,101,238,0.4);"
          />
          <button
            type="submit"
            class="h-11 rounded-[10px] px-7 text-sm font-semibold text-white transition-all hover:-translate-y-0.5"
            style="background: #8365EE; box-shadow: 0 2px 0 rgba(131,101,238,0);"
            onmouseover="this.style.boxShadow='0 6px 20px rgba(131,101,238,0.35)'"
            onmouseout="this.style.boxShadow='0 2px 0 rgba(131,101,238,0)'"
          >
            Subscribe →
          </button>
        </form>

        <!-- Fine print -->
        <p class="mt-4 text-xs" style="color: var(--color-bid-text-tertiary);">
          Monthly. No spam. Unsubscribe any time.
        </p>
      </div>

      <!-- Divider -->
      <div
        class="relative mx-auto mt-12 max-w-xs border-t"
        style="border-color: var(--color-bid-border);"
      ></div>

      <!-- Contact links -->
      <div class="relative mx-auto mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center sm:gap-6">
        <p class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-bid-text-tertiary);">
          Or reach out directly
        </p>
        <a
          href="mailto:haileyamullen@gmail.com"
          class="flex items-center gap-2 text-sm font-medium transition-opacity hover:opacity-70"
          style="color: var(--color-bid-text-secondary);"
        >
          <span style="color: var(--color-bid-coral);">✉</span>
          haileyamullen@gmail.com
        </a>
        <a
          href="https://www.linkedin.com/in/hailey-mullen/"
          target="_blank"
          rel="noreferrer noopener"
          class="flex items-center gap-2 text-sm font-medium transition-opacity hover:opacity-70"
          style="color: var(--color-bid-text-secondary);"
        >
          <span style="color: var(--color-bid-slate);">in</span>
          LinkedIn
        </a>
      </div>

    </div>
  </div>
</section>
