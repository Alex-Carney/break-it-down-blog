---
/**
 * BidHeroCanvas — Full-viewport hero with animated network-flow canvas.
 * Dark mode shows glowing luminous lines on deep navy.
 * Light mode shows bold lines that fade toward the text-reading center.
 * Two canvas elements swap via CSS opacity on theme change.
 */
import { getLocaleFromUrl, getLocalizedRoute } from "@/js/localeUtils";
import { getTranslatedData } from "@/js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<section
  class="relative isolate flex min-h-[100svh] w-full items-center justify-center overflow-hidden"
  aria-label="Hero section"
>
  <!-- Dark mode canvas -->
  <canvas
    id="hero-canvas-dark"
    class="pointer-events-none absolute inset-0 h-full w-full transition-opacity duration-500"
    aria-hidden="true"
  ></canvas>
  <!-- Light mode canvas -->
  <canvas
    id="hero-canvas-light"
    class="pointer-events-none absolute inset-0 h-full w-full transition-opacity duration-500"
    aria-hidden="true"
  ></canvas>

  <div class="relative z-10 mx-auto max-w-[720px] px-6 py-32 text-center">
    <!-- Badge -->
    <div
      class="mb-7 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.1em]"
      style="color: var(--color-bid-coral); background: rgba(107,79,207,0.06); border-color: rgba(107,79,207,0.18);"
    >
      ◦ Complex Systems. Explained Clearly.
    </div>

    <!-- Title -->
    <h1
      class="mb-5 font-heading text-[clamp(2.75rem,7vw,4.5rem)] font-extrabold leading-[1.05] tracking-tight"
      style="color: var(--color-bid-coral);"
    >
      {siteData.name}
    </h1>

    <!-- Subtitle -->
    <p
      class="mx-auto mb-9 max-w-[520px] text-[clamp(1rem,2.2vw,1.1875rem)] leading-[1.65]"
      style="font-family: var(--font-serif); color: var(--color-bid-text-secondary);"
    >
      Technology. AI. Organizations. Strategy. Each issue takes one complex system,
      breaks it into its working parts, and shows you what the evidence actually reveals.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-3">
      <a
        href="/blog"
        class="inline-flex items-center rounded-[10px] px-7 py-3.5 text-[15px] font-semibold text-white transition-all hover:-translate-y-0.5"
        style="background: #8365EE; box-shadow: 0 2px 0 rgba(131,101,238,0);"
        onmouseover="this.style.boxShadow='0 6px 24px rgba(131,101,238,0.35)'"
        onmouseout="this.style.boxShadow='0 2px 0 rgba(131,101,238,0)'"
      >
        Read Latest →
      </a>
      <a
        href="/about"
        class="inline-flex items-center rounded-[10px] border px-7 py-3.5 text-[15px] font-semibold transition-all hover:-translate-y-0.5"
        style="background: var(--color-bid-surface); color: var(--color-bid-text); border-color: var(--color-bid-border);"
      >
        About Me
      </a>
    </div>
  </div>
</section>

<style>
  /* Dark canvas visible in dark mode, light canvas visible in light mode */
  :global(.dark) #hero-canvas-dark { opacity: 1; }
  :global(.dark) #hero-canvas-light { opacity: 0; }
  #hero-canvas-dark { opacity: 0; }
  #hero-canvas-light { opacity: 1; }
</style>

<script>
  const PURPLE = "#8365EE", BLUE = "#4A7CCE", TEAL = "#0EA5A5";
  const LP = "#7B5CE0", LB = "#5080D0", LT = "#12A0A0";
  const LP2 = "#8B6CE8", LB2 = "#4A72C0", LT2 = "#0E9898";

  function drawHeroDark() {
    const canvas = document.getElementById("hero-canvas-dark") as HTMLCanvasElement | null;
    if (!canvas) return;
    const rect = canvas.parentElement!.getBoundingClientRect();
    const w = rect.width || window.innerWidth;
    const h = rect.height || window.innerHeight;
    canvas.width = w * 1.5;
    canvas.height = h * 1.5;
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    const ctx = canvas.getContext("2d")!;
    ctx.scale(1.5, 1.5);

    const bg = ctx.createRadialGradient(w * 0.4, h * 0.35, 0, w * 0.5, h * 0.5, w * 0.8);
    bg.addColorStop(0, "#100C28");
    bg.addColorStop(1, "#08061A");
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, w, h);

    // Stars
    for (let i = 0; i < 80; i++) {
      ctx.beginPath();
      ctx.arc(Math.random() * w, Math.random() * h, 0.3 + Math.random() * 0.7, 0, Math.PI * 2);
      ctx.fillStyle = "#FFF";
      ctx.globalAlpha = 0.12 + Math.random() * 0.25;
      ctx.fill();
    }

    const cols = [PURPLE, BLUE, TEAL, PURPLE, BLUE, TEAL, PURPLE];
    for (let i = 0; i < 26; i++) {
      const sy = (i / 26) * h;
      const amp = 20 + Math.random() * 45;
      const freq = 0.004 + Math.random() * 0.004;
      const ph = Math.random() * Math.PI * 2;
      const col = cols[i % 7];
      const alpha = 0.15 + Math.random() * 0.4;

      // Glow pass
      ctx.beginPath();
      ctx.globalAlpha = alpha * 0.15;
      for (let x = -10; x <= w + 10; x += 3) {
        const y = sy + Math.sin(x * freq + ph) * amp + Math.sin(x * freq * 2.1 + ph * 1.7) * amp * 0.3;
        x === -10 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = col;
      ctx.lineWidth = 8;
      ctx.stroke();

      // Main line
      ctx.beginPath();
      ctx.globalAlpha = alpha;
      for (let x = -10; x <= w + 10; x += 3) {
        const y = sy + Math.sin(x * freq + ph) * amp + Math.sin(x * freq * 2.1 + ph * 1.7) * amp * 0.3;
        x === -10 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = col;
      ctx.lineWidth = 1;
      ctx.stroke();

      // Nodes
      for (let j = 0; j < 3; j++) {
        const nx = Math.random() * w;
        const ny = sy + Math.sin(nx * freq + ph) * amp + Math.sin(nx * freq * 2.1 + ph * 1.7) * amp * 0.3;
        const g = ctx.createRadialGradient(nx, ny, 0, nx, ny, 5);
        g.addColorStop(0, "#FFF");
        g.addColorStop(0.3, col);
        g.addColorStop(1, "transparent");
        ctx.globalAlpha = 0.5 + Math.random() * 0.5;
        ctx.fillStyle = g;
        ctx.fillRect(nx - 5, ny - 5, 10, 10);
      }
    }
    ctx.globalAlpha = 1;
  }

  function drawHeroLight() {
    const canvas = document.getElementById("hero-canvas-light") as HTMLCanvasElement | null;
    if (!canvas) return;
    const rect = canvas.parentElement!.getBoundingClientRect();
    const w = rect.width || window.innerWidth;
    const h = rect.height || window.innerHeight;
    canvas.width = w * 1.5;
    canvas.height = h * 1.5;
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    const ctx = canvas.getContext("2d")!;
    ctx.scale(1.5, 1.5);

    ctx.fillStyle = "#F6F5F9";
    ctx.fillRect(0, 0, w, h);

    const cols = [LP, LB, LT, LP2, LB2, LT2];
    const centerX = w * 0.5, centerY = h * 0.52;
    const clearR = Math.min(w, h) * 0.42;

    for (let i = 0; i < 24; i++) {
      const sy = (i / 24) * h;
      const amp = 18 + Math.random() * 42;
      const freq = 0.003 + Math.random() * 0.004;
      const ph = Math.random() * Math.PI * 2;
      const col = cols[i % 6];
      const base = 0.35 + Math.random() * 0.25;

      const pts: [number, number][] = [];
      for (let x = -10; x <= w + 10; x += 3) {
        const y = sy + Math.sin(x * freq + ph) * amp + Math.sin(x * freq * 2.3 + ph * 1.5) * amp * 0.25;
        pts.push([x, y]);
      }

      for (let p = 0; p < pts.length - 1; p++) {
        const mx = (pts[p][0] + pts[p + 1][0]) / 2;
        const my = (pts[p][1] + pts[p + 1][1]) / 2;
        const dist = Math.sqrt((mx - centerX) ** 2 + (my - centerY) ** 2);
        const fade = Math.min(1, Math.max(0.05, (dist - clearR * 0.5) / (clearR * 0.8)));

        ctx.beginPath();
        ctx.moveTo(pts[p][0], pts[p][1]);
        ctx.lineTo(pts[p + 1][0], pts[p + 1][1]);
        ctx.globalAlpha = base * 0.25 * fade;
        ctx.strokeStyle = col;
        ctx.lineWidth = 5;
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(pts[p][0], pts[p][1]);
        ctx.lineTo(pts[p + 1][0], pts[p + 1][1]);
        ctx.globalAlpha = base * fade;
        ctx.strokeStyle = col;
        ctx.lineWidth = 1.2;
        ctx.stroke();
      }

      for (let j = 0; j < 4; j++) {
        const nx = Math.random() * w;
        const ny = sy + Math.sin(nx * freq + ph) * amp + Math.sin(nx * freq * 2.3 + ph * 1.5) * amp * 0.25;
        const dist = Math.sqrt((nx - centerX) ** 2 + (ny - centerY) ** 2);
        const fade = Math.min(1, Math.max(0, (dist - clearR * 0.4) / (clearR * 0.7)));
        if (fade < 0.1) continue;
        const g = ctx.createRadialGradient(nx, ny, 0, nx, ny, 5);
        g.addColorStop(0, col);
        g.addColorStop(0.4, col + "50");
        g.addColorStop(1, "transparent");
        ctx.globalAlpha = 0.4 * fade;
        ctx.fillStyle = g;
        ctx.fillRect(nx - 5, ny - 5, 10, 10);
        ctx.beginPath();
        ctx.arc(nx, ny, 0.8, 0, Math.PI * 2);
        ctx.globalAlpha = 0.7 * fade;
        ctx.fillStyle = "#FFF";
        ctx.fill();
      }
    }
    ctx.globalAlpha = 1;
  }

  function drawHero() {
    drawHeroDark();
    drawHeroLight();
  }

  drawHero();

  window.addEventListener("resize", drawHero, { passive: true });
  document.addEventListener("astro:after-swap", drawHero);
</script>
