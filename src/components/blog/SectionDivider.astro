---
/**
 * SectionDivider — Visual transition between sections or within a case study.
 * Can be a simple decorative break or carry a pivoting statement.
 *
 * Usage in MDX:
 *   import SectionDivider from '@components/bid/SectionDivider.astro'
 *
 *   <SectionDivider />
 *
 *   <SectionDivider statement="Then it got more complicated." />
 */

interface Props {
  statement?: string;
}

const { statement } = Astro.props;
---

{statement ? (
  <div class="bid-section-divider my-10 not-content flex items-center gap-6">
    <div class="flex-1 h-px bg-bid-border"></div>
    <p class="text-sm font-sans italic text-bid-text-secondary whitespace-nowrap">
      {statement}
    </p>
    <div class="flex-1 h-px bg-bid-border"></div>
  </div>
) : (
  <div class="bid-section-divider my-10 not-content">
    <div class="flex justify-center gap-2">
      <div class="w-1 h-1 rounded-full bg-bid-text-tertiary/40"></div>
      <div class="w-1 h-1 rounded-full bg-bid-text-tertiary/40"></div>
      <div class="w-1 h-1 rounded-full bg-bid-text-tertiary/40"></div>
    </div>
  </div>
)}
